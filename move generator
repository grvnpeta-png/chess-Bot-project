from board_state import Board
from move_generator import MoveGenerator
from engine_evaluation import Evaluation

class Search:
    """Runs a depth-bounded Alpha-Beta search and records position telemetry data."""
    def __init__(self):
        self.generator = MoveGenerator()
        self.telemetry_records: List[Dict[str, Any]] = []

    def run_search(self, board: Board, depth: int) -> tuple:
        """Finds the best available legal move for the current side to move."""
        best_move = None
        best_value = -9999999
        alpha = -9999999
        beta = 9999999
        
        legal_moves = self.generator.generate_moves(board)
        if len(legal_moves) == 0:
            return None, Evaluation.evaluate(board)
            
        # Basic positional move ordering based on capture flag properties
        ordered_moves = sorted(legal_moves, key=lambda m: m.move_flag, reverse=True)
        
        for move in ordered_moves:
            state_hist = board.make_move(move)
            score = -self._alpha_beta(board, depth - 1, -beta, -alpha)
            board.unmake_move(move, state_hist)
            
            # Log structural metrics to data science buffer pipelines
            self.telemetry_records.append({
                "active_color": board.move_colour,
                "legal_moves_count": len(legal_moves),
                "move_flag": move.move_flag,
                "calculated_score": score
            })
            
            if score > best_value:
                best_value = score
                best_move = move
            alpha = max(alpha, score)
            
        return best_move, best_value

    def _alpha_beta(self, board: Board, depth: int, alpha: int, beta: int) -> int:
        if depth == 0:
            return Evaluation.evaluate(board)
            
        moves = self.generator.generate_moves(board)
        if len(moves) == 0:
            return Evaluation.evaluate(board) # Resolves terminal node evaluations
            
        for move in moves:
            state = board.make_move(move)
            score = -self._alpha_beta(board, depth - 1, -beta, -alpha)
            board.unmake_move(move, state)
            
            if score >= beta:
                return beta
            alpha = max(alpha, score)
        return alpha

    def export_telemetry_to_csv(self, filename: str = "engine_training_dataset.csv"):
        """Exports the accumulated position analytics into a standardized dataset."""
        df = pd.DataFrame(self.telemetry_records)
        df.to_csv(filename, index=False)
        print(f" Successfully synchronized {len(df)} records into target file: {filename}")


