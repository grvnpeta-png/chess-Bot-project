# =====================================================================
# STUBS & COORD SUPPORT
# =====================================================================
class Board:
    WhiteIndex = 0
    BlackIndex = 1

class BoardHelper:
    @staticmethod
    def file_index(square): return square % 8
    @staticmethod
    def rank_index(square): return square // 8
    @staticmethod
    def index_from_coord(file, rank): return rank * 8 + file

class Coord:
    def __init__(self, square_index_or_file, rank_index=None):
        if rank_index is None:
            self.file_index = square_index_or_file % 8
            self.rank_index = square_index_or_file // 8
        else:
            self.file_index = square_index_or_file
            self.rank_index = rank_index

    def is_valid_square(self):
        return 0 <= self.file_index < 8 and 0 <= self.rank_index < 8

    @property
    def square_index(self):
        return self.rank_index * 8 + self.file_index


# =====================================================================
# STRUCTURAL EVALUATION DATA RECORD
# =====================================================================
class EvaluationData:
    def __init__(self):
        self.material_score = 0
        self.mop_up_score = 0
        self.piece_square_score = 0
        self.pawn_score = 0
        self.pawn_shield_score = 0

    def sum(self):
        return (self.material_score + self.mop_up_score + 
                self.piece_square_score + self.pawn_score + self.pawn_shield_score)

    def to_dict(self):
        return {
            "material": self.material_score,
            "mop_up": self.mop_up_score,
            "piece_square": self.piece_square_score,
            "pawns": self.pawn_score,
            "pawn_shield": self.pawn_shield_score,
            "total": self.sum()
        }


# =====================================================================
# 📊 MATERIAL CONTEXT STRUCTURE (With Phase Transition Tracking)
# =====================================================================
class MaterialInfo:
    """Structures material weights and tracks game-phase decay."""
    def __init__(self, num_pawns, num_knights, num_bishops, num_queens, num_rooks, my_pawns, enemy_pawns, eval_instance):
        self.num_pawns = num_pawns
        self.num_bishops = num_bishops
        self.num_queens = num_queens
        self.num_rooks = num_rooks
        self.pawns = my_pawns
        self.enemy_pawns = enemy_pawns

        self.num_majors = num_rooks + num_queens
        self.num_minors = num_bishops + num_knights

        # Accumulate absolute baseline values
        self.material_score = (
            num_pawns * eval_instance.PawnValue +
            num_knights * eval_instance.KnightValue +
            num_bishops * eval_instance.BishopValue +
            num_rooks * eval_instance.RookValue +
            num_queens * eval_instance.QueenValue
        )

        # Non-linear Game Phase Weights (0.0 = Opening, 1.0 = Clean Endgame)
        queen_weight, rook_weight, bishop_weight, knight_weight = 45, 20, 10, 10
        endgame_start_weight = 2 * rook_weight + 2 * bishop_weight + 2 * knight_weight + queen_weight
        
        weight_sum = (num_queens * queen_weight + num_rooks * rook_weight + 
                      num_bishops * bishop_weight + num_knights * knight_weight)
        
        self.endgame_t = 1.0 - min(1.0, weight_sum / float(endgame_start_weight))


