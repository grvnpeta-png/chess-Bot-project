    tables_map = {}

    @classmethod
    def initialize_tables(cls, piece_class):
        def get_flipped_table(table):
            flipped = [0] * 64
            for idx in range(64):
                c = Coord(idx)
                flipped_coord = Coord(c.file_index, 7 - c.rank_index)
                flipped[flipped_coord.square_index] = table[idx]
            return flipped

        # Map white arrays
        cls.tables_map[(piece_class.Pawn, True)] = cls.Pawns
        cls.tables_map[(piece_class.Rook, True)] = cls.Rooks
        cls.tables_map[(piece_class.Knight, True)] = cls.Knights
        cls.tables_map[(piece_class.Bishop, True)] = cls.Bishops
        cls.tables_map[(piece_class.Queen, True)] = cls.Queens

        # Map black arrays mirrored across ranks
        cls.tables_map[(piece_class.Pawn, False)] = get_flipped_table(cls.Pawns)
        cls.tables_map[(piece_class.Rook, False)] = get_flipped_table(cls.Rooks)
        cls.tables_map[(piece_class.Knight, False)] = get_flipped_table(cls.Knights)
        cls.tables_map[(piece_class.Bishop, False)] = get_flipped_table(cls.Bishops)
        cls.tables_map[(piece_class.Queen, False)] = get_flipped_table(cls.Queens)

    @classmethod
    def read(cls, table_array, square, is_white):
        if is_white:
            file = BoardHelper.file_index(square)
            rank = 7 - BoardHelper.rank_index(square)
            square = BoardHelper.index_from_coord(file, rank)
        return table_array[square]


# =====================================================================
# KING PROTECTION MATRIX (Precomputed Shield Offsets)
# =====================================================================
class PrecomputedEvaluationData:
    PawnShieldSquaresWhite = [[] for _ in range(64)]
    PawnShieldSquaresBlack = [[] for _ in range(64)]

    @classmethod
    def initialize_shield_arrays(cls):
        for sq in range(64):
            shield_white = []
            shield_black = []
            coord = Coord(sq)
            rank = coord.rank_index
            file = np.clip(coord.file_index, 1, 6)

            # Row offsets +1 / -1
            for file_offset in range(-1, 2):
                c_w = Coord(file + file_offset, rank + 1)
                c_b = Coord(file + file_offset, rank - 1)
                if c_w.is_valid_square(): shield_white.append(c_w.square_index)
                if c_b.is_valid_square(): shield_black.append(c_b.square_index)

            # Row offsets +2 / -2
            for file_offset in range(-1, 2):
                c_w = Coord(file + file_offset, rank + 2)
                c_b = Coord(file + file_offset, rank - 2)
                if c_w.is_valid_square(): shield_white.append(c_w.square_index)
                if c_b.is_valid_square(): shield_black.append(c_b.square_index)

            cls.PawnShieldSquaresWhite[sq] = shield_white
            cls.PawnShieldSquaresBlack[sq] = shield_black


# Initialize precomputations immediately on import
PrecomputedEvaluationData.initialize_shield_arrays()


